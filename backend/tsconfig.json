{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": false,

    "typeRoots": ["./node_modules/@types"],

    "types": ["node"],
    "moduleResolution": "node16",
    "lib": ["ES2020"],
    "skipLibCheck": true
  },
  "include": ["src"]
}